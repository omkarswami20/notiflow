# ─────────────────────────────────────
# Database
# ─────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST/notiflow?sslmode=require&channel_binding=require

# ─────────────────────────────────────
# Server
# ─────────────────────────────────────
PORT=3000

# ─────────────────────────────────────
# JWT
# ─────────────────────────────────────
JWT_ACCESS_SECRET=your_access_secret_key_here
JWT_REFRESH_SECRET=your_refresh_secret_key_here
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# ─────────────────────────────────────
# Redis (Upstash)
# ─────────────────────────────────────
REDIS_URL="rediss://default:YOUR_PASSWORD@YOUR_HOST:6379"

# ─────────────────────────────────────
# Resend Email Service
# Note: Render free tier blocks outbound SMTP ports (25, 465, 587).
# We use Resend.com API for reliable email delivery.
# Step 1: Create a free account on resend.com
# Step 2: Generate an API key and paste it below
# Step 3: Use "onboarding@resend.dev" as the sender (SMTP_FROM) if you don't have a custom domain.
# ─────────────────────────────────────
RESEND_API_KEY=re_your_api_key_here
SMTP_FROM="NotiFlow <onboarding@resend.dev>"

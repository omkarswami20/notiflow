# ─────────────────────────────────────
# Database
# ─────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST/notiflow?sslmode=require&channel_binding=require

# ─────────────────────────────────────
# Server
# ─────────────────────────────────────
PORT=3000

# ─────────────────────────────────────
# JWT
# ─────────────────────────────────────
JWT_ACCESS_SECRET=your_access_secret_key_here
JWT_REFRESH_SECRET=your_refresh_secret_key_here
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# ─────────────────────────────────────
# Redis (Upstash)
# ─────────────────────────────────────
REDIS_URL="rediss://default:YOUR_PASSWORD@YOUR_HOST:6379"

# ─────────────────────────────────────
# SMTP (Gmail)
# Step 1: Enable 2-Step Verification on your Google account
# Step 2: Go to myaccount.google.com → Security → App passwords
# Step 3: Create an app password named "Notiflow"
# Step 4: Paste the 16-character password below (no spaces)
# ─────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM="NotiFlow <your_gmail@gmail.com>"

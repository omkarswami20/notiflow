# ─────────────────────────────────────
# Database
# ─────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST/notiflow?sslmode=require&channel_binding=require

# ─────────────────────────────────────
# Server
# ─────────────────────────────────────
PORT=3000

# ─────────────────────────────────────
# JWT
# ─────────────────────────────────────
JWT_ACCESS_SECRET=your_access_secret_key_here
JWT_REFRESH_SECRET=your_refresh_secret_key_here
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# ─────────────────────────────────────
# Redis (Upstash)
# ─────────────────────────────────────
REDIS_URL="rediss://default:YOUR_PASSWORD@YOUR_HOST:6379"

# ─────────────────────────────────────
# Email Configuration (Hybrid: Resend vs Brevo vs SMTP)
# ─────────────────────────────────────
# Option A - Brevo API (Recommended for Free Prod/Render - No Domain Needed):
# 1. Sign up on brevo.com, add & verify your Gmail sender under Senders & IPs.
# 2. Generate an API Key under SMTP & API, set BREVO_API_KEY and SMTP_FROM below.
#
# Option B - Resend API (Requires Custom Domain for sending to others):
# 1. Create a free account on resend.com and generate an API key.
# 2. Add RESEND_API_KEY and set SMTP_FROM to your domain/onboarding@resend.dev.
# 
# Option C - SMTP (Gmail App Password - Local Development Only):
# 1. Configure SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS, and SMTP_FROM.
# ─────────────────────────────────────
BREVO_API_KEY=
RESEND_API_KEY=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM="NotiFlow <your_gmail@gmail.com>"
